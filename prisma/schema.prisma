generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Enum per lo stato dei contenuti
enum ContentStatus {
  NON_IMPOSTATO
  NUOVO
  AGGIORNATO
}

model Kit {
  id              String        @id
  name            String
  team            String
  type            String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  status          ContentStatus @default(NON_IMPOSTATO)

  // Flag per indicare la presenza di file (per performance)
  hasImage        Boolean       @default(false)
  hasLogo         Boolean       @default(false)
  hasModel3D      Boolean       @default(false)
  hasDetail1      Boolean       @default(false)
  hasDetail2      Boolean       @default(false)
  hasDetail3      Boolean       @default(false)
  hasDetail4      Boolean       @default(false)
  hasDetail5      Boolean       @default(false)
  hasDetail6      Boolean       @default(false)

  // Immagine principale del kit (BLOB)
  imageData       Bytes?
  imageMimeType   String?

  // Logo della squadra (BLOB)
  logoData        Bytes?
  logoMimeType    String?

  // Modello 3D (BLOB)
  model3DData     Bytes?
  model3DName     String?     // Nome originale del file

  // Dettagli del kit (BLOB)
  detail1Label    String?
  detail1Data     Bytes?
  detail1MimeType String?

  detail2Label    String?
  detail2Data     Bytes?
  detail2MimeType String?

  detail3Label    String?
  detail3Data     Bytes?
  detail3MimeType String?

  detail4Label    String?
  detail4Data     Bytes?
  detail4MimeType String?

  detail5Label    String?
  detail5Data     Bytes?
  detail5MimeType String?

  detail6Label    String?
  detail6Data     Bytes?
  detail6MimeType String?

  // Voti
  likes           Int           @default(0)
  dislikes        Int           @default(0)

  PlayerKit       PlayerKit[]
  KitVote         KitVote[]
  Comment         Comment[]
  KitViewer3DConfig KitViewer3DConfig?
}

model Nation {
  id        String   @id
  name      String   @unique
  code      String   @unique
  flag      String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  Player    Player[]
}

model Player {
  id            String        @id
  name          String
  surname       String?
  nationId      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  biography     String?
  status        ContentStatus @default(NON_IMPOSTATO)

  // Flag per indicare la presenza di immagine (per performance)
  hasImage      Boolean       @default(false)

  // Immagine del giocatore (BLOB)
  imageData     Bytes?
  imageMimeType String?

  Nation        Nation?       @relation(fields: [nationId], references: [id])
  PlayerKit     PlayerKit[]
}

model PlayerKit {
  id        String   @id
  playerId  String
  kitId     String
  createdAt DateTime @default(now())
  updatedAt DateTime
  Player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  Kit       Kit      @relation(fields: [kitId], references: [id], onDelete: Cascade)

  @@unique([playerId, kitId])
}

model PageView {
  id        String   @id @default(uuid())
  page      String
  createdAt DateTime @default(now())
  userAgent String?
  ip        String?
}

model KitVote {
  id        String   @id @default(uuid())
  kitId     String
  userId    String   // Identificatore univoco dell'utente (cookie-based)
  voteType  String   // 'like' o 'dislike'
  createdAt DateTime @default(now())
  Kit       Kit      @relation(fields: [kitId], references: [id], onDelete: Cascade)

  @@unique([kitId, userId]) // Un utente può votare solo una volta per kit
}

model Comment {
  id        String    @id @default(uuid())
  author    String
  content   String
  userId    String    @default("legacy-user") // Identificatore univoco dell'autore (cookie-based)
  kitId     String?   // Opzionale: per contestualizzare il commento a un kit
  parentId  String?   // Opzionale: per le risposte ad altri commenti
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Voti
  likes     Int       @default(0)
  dislikes  Int       @default(0)

  Kit       Kit?      @relation(fields: [kitId], references: [id], onDelete: SetNull)
  Parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  Replies   Comment[] @relation("CommentReplies")
  CommentVote CommentVote[]
}

model CommentVote {
  id        String   @id @default(uuid())
  commentId String
  userId    String   // Identificatore univoco dell'utente (cookie-based)
  voteType  String   // 'like' o 'dislike'
  createdAt DateTime @default(now())
  Comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId]) // Un utente può votare solo una volta per commento
}

model Admin {
  id        String   @id @default("admin")
  nickname  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Viewer3DConfig {
  id        String   @id @default("viewer3d-config")
  updatedAt DateTime @updatedAt

  // === CAMERA ===
  cameraInitialDistance Float   @default(6)
  cameraFov             Float   @default(50)
  cameraMinDistance     Float   @default(3.5)
  cameraMaxDistance     Float   @default(6)

  // === ROTAZIONE (angoli in gradi, convertiti in radianti) ===
  cameraFreeRotation     Boolean @default(false) // Rotazione libera a 360°
  rotationMinPolarAngle Float   @default(90)  // 90 gradi = PI/2 radianti
  rotationMaxPolarAngle Float   @default(90)

  // === AUTO-ROTATION ===
  autoRotateEnabled   Boolean @default(true)
  autoRotateSpeed     Float   @default(1.5)
  autoRotateResumeDelay Int   @default(2000)

  // === CONTROLLI ===
  controlsEnablePan          Boolean @default(true)
  controlsEnablePanHorizontal Boolean @default(false)
  controlsEnablePanVertical  Boolean @default(true)
  controlsRotateSpeed        Float   @default(0.5)
  controlsZoomSpeed          Float   @default(1.2)
  controlsPanSpeed           Float   @default(1)
  controlsEnableDamping      Boolean @default(true)
  controlsDampingFactor      Float   @default(0.05)
  controlsMaxPanHorizontal   Float   @default(3)
  controlsMaxPanVertical     Float   @default(2)

  // === MODELLO ===
  modelTargetSize Float @default(5)

  // === ILLUMINAZIONE ===
  lightingAmbientIntensity Float @default(0.7)
  lightingMainLightPositionX Float @default(5)
  lightingMainLightPositionY Float @default(10)
  lightingMainLightPositionZ Float @default(7.5)
  lightingMainLightIntensity Float @default(1.5)
  lightingSecondaryLightPositionX Float @default(-5)
  lightingSecondaryLightPositionY Float @default(5)
  lightingSecondaryLightPositionZ Float @default(-7.5)
  lightingSecondaryLightIntensity Float @default(0.8)

  // === OMBRE ===
  shadowsEnabled  Boolean @default(true)
  shadowsPositionX Float   @default(0)
  shadowsPositionY Float   @default(-2.45)
  shadowsPositionZ Float   @default(0)
  shadowsOpacity   Float   @default(0.5)
  shadowsScale     Float   @default(10)
  shadowsBlur      Float   @default(2)
  shadowsFar       Float   @default(10)
  shadowsResolution Int    @default(1024)

  // === EFFETTI POST-PROCESSING ===
  effectsEnabled       Boolean @default(true)
  effectsEnvMapIntensity Float @default(1.5)
  effectsRoughness     Float   @default(0.4)
  effectsMetalness     Float   @default(0.1)
  effectsToneMappingWhitePoint Float @default(4.0)
  effectsToneMappingMiddleGrey Float @default(0.6)
  effectsVignetteOffset Float  @default(0.3)
  effectsVignetteDarkness Float @default(0.5)

  // === BLOOM ===
  bloomEnabled Boolean @default(false)
  bloomIntensity Float @default(0.5)
  bloomLuminanceThreshold Float @default(0.9)
  bloomLuminanceSmoothing Float @default(0.025)

  // === AMBIENT OCCLUSION (N8AO) ===
  aoEnabled Boolean @default(false)
  aoIntensity Float @default(2.0)
  aoDistance Float @default(0.2)
  aoFalloff Float @default(0.01)

  // === BRIGHTNESS / CONTRAST ===
  brightnessContrastEnabled Boolean @default(false)
  brightness Float @default(0)
  contrast Float @default(0)

  // === HUE / SATURATION ===
  hueSaturationEnabled Boolean @default(false)
  hue Float @default(0)
  saturation Float @default(0)

  // === CHROMATIC ABERRATION ===
  chromaticAberrationEnabled Boolean @default(false)
  chromaticAberrationOffset Float @default(0.002)

  // === DEPTH OF FIELD ===
  depthOfFieldEnabled Boolean @default(false)
  depthOfFieldFocusDistance Float @default(0.01)
  depthOfFieldFocalLength Float @default(0.02)
  depthOfFieldBokehScale Float @default(3)

  // === TILT SHIFT ===
  tiltShiftEnabled Boolean @default(false)
  tiltShiftBlur Float @default(0.05)
  tiltShiftStart Float @default(0.49)
  tiltShiftEnd Float @default(0.5)

  // === NOISE ===
  noiseEnabled Boolean @default(false)
  noiseOpacity Float @default(0.05)

  // === DOT SCREEN ===
  dotScreenEnabled Boolean @default(false)
  dotScreenAngle Float @default(1.39)
  dotScreenScale Float @default(1)

  // === PIXELATION ===
  pixelationEnabled Boolean @default(false)
  pixelationGranularity Int @default(5)

  // === SCANLINE ===
  scanlineEnabled Boolean @default(false)
  scanlineDensity Float @default(1.5)
  scanlineOpacity Float @default(0.1)

  // === GLITCH ===
  glitchEnabled Boolean @default(false)
  glitchDelay Float @default(3)
  glitchDuration Float @default(0.6)
  glitchStrength Float @default(0.3)

  // === BACKGROUND ===
  backgroundColor String @default("#1a1a1a")  // Colore esadecimale (usato anche in fullscreen)
}

// Configurazione del visualizzatore 3D per singolo kit
model KitViewer3DConfig {
  id        String   @id @default(uuid())
  kitId     String   @unique
  updatedAt DateTime @updatedAt

  // === CAMERA ===
  cameraInitialDistance Float   @default(6)
  cameraFov             Float   @default(50)
  cameraMinDistance     Float   @default(3.5)
  cameraMaxDistance     Float   @default(6)

  // === ROTAZIONE ===
  cameraFreeRotation     Boolean @default(false)
  rotationMinPolarAngle Float   @default(90)
  rotationMaxPolarAngle Float   @default(90)

  // === AUTO-ROTATION ===
  autoRotateEnabled   Boolean @default(true)
  autoRotateSpeed     Float   @default(1.5)
  autoRotateResumeDelay Int   @default(2000)

  // === CONTROLLI ===
  controlsEnablePan          Boolean @default(true)
  controlsEnablePanHorizontal Boolean @default(false)
  controlsEnablePanVertical  Boolean @default(true)
  controlsRotateSpeed        Float   @default(0.5)
  controlsZoomSpeed          Float   @default(1.2)
  controlsPanSpeed           Float   @default(1)
  controlsEnableDamping      Boolean @default(true)
  controlsDampingFactor      Float   @default(0.05)
  controlsMaxPanHorizontal   Float   @default(3)
  controlsMaxPanVertical     Float   @default(2)

  // === MODELLO ===
  modelTargetSize Float @default(5)

  // === ILLUMINAZIONE ===
  lightingAmbientIntensity Float @default(0.7)
  lightingMainLightPositionX Float @default(5)
  lightingMainLightPositionY Float @default(10)
  lightingMainLightPositionZ Float @default(7.5)
  lightingMainLightIntensity Float @default(1.5)
  lightingSecondaryLightPositionX Float @default(-5)
  lightingSecondaryLightPositionY Float @default(5)
  lightingSecondaryLightPositionZ Float @default(-7.5)
  lightingSecondaryLightIntensity Float @default(0.8)

  // === OMBRE ===
  shadowsEnabled  Boolean @default(true)
  shadowsPositionX Float   @default(0)
  shadowsPositionY Float   @default(-2.45)
  shadowsPositionZ Float   @default(0)
  shadowsOpacity   Float   @default(0.5)
  shadowsScale     Float   @default(10)
  shadowsBlur      Float   @default(2)
  shadowsFar       Float   @default(10)
  shadowsResolution Int    @default(1024)

  // === EFFETTI POST-PROCESSING ===
  effectsEnabled       Boolean @default(true)
  effectsEnvMapIntensity Float @default(1.5)
  effectsRoughness     Float   @default(0.4)
  effectsMetalness     Float   @default(0.1)
  effectsToneMappingWhitePoint Float @default(4.0)
  effectsToneMappingMiddleGrey Float @default(0.6)
  effectsVignetteOffset Float  @default(0.3)
  effectsVignetteDarkness Float @default(0.5)

  // === BLOOM ===
  bloomEnabled Boolean @default(false)
  bloomIntensity Float @default(0.5)
  bloomLuminanceThreshold Float @default(0.9)
  bloomLuminanceSmoothing Float @default(0.025)

  // === AMBIENT OCCLUSION (N8AO) ===
  aoEnabled Boolean @default(false)
  aoIntensity Float @default(2.0)
  aoDistance Float @default(0.2)
  aoFalloff Float @default(0.01)

  // === BRIGHTNESS / CONTRAST ===
  brightnessContrastEnabled Boolean @default(false)
  brightness Float @default(0)
  contrast Float @default(0)

  // === HUE / SATURATION ===
  hueSaturationEnabled Boolean @default(false)
  hue Float @default(0)
  saturation Float @default(0)

  // === CHROMATIC ABERRATION ===
  chromaticAberrationEnabled Boolean @default(false)
  chromaticAberrationOffset Float @default(0.002)

  // === DEPTH OF FIELD ===
  depthOfFieldEnabled Boolean @default(false)
  depthOfFieldFocusDistance Float @default(0.01)
  depthOfFieldFocalLength Float @default(0.02)
  depthOfFieldBokehScale Float @default(3)

  // === TILT SHIFT ===
  tiltShiftEnabled Boolean @default(false)
  tiltShiftBlur Float @default(0.05)
  tiltShiftStart Float @default(0.49)
  tiltShiftEnd Float @default(0.5)

  // === NOISE ===
  noiseEnabled Boolean @default(false)
  noiseOpacity Float @default(0.05)

  // === DOT SCREEN ===
  dotScreenEnabled Boolean @default(false)
  dotScreenAngle Float @default(1.39)
  dotScreenScale Float @default(1)

  // === PIXELATION ===
  pixelationEnabled Boolean @default(false)
  pixelationGranularity Int @default(5)

  // === SCANLINE ===
  scanlineEnabled Boolean @default(false)
  scanlineDensity Float @default(1.5)
  scanlineOpacity Float @default(0.1)

  // === GLITCH ===
  glitchEnabled Boolean @default(false)
  glitchDelay Float @default(3)
  glitchDuration Float @default(0.6)
  glitchStrength Float @default(0.3)

  // === BACKGROUND ===
  backgroundColor String @default("#1a1a1a")

  // === RELAZIONE ===
  Kit Kit @relation(fields: [kitId], references: [id], onDelete: Cascade)
}

// Preset configurazione viewer 3D (salvato come JSON)
model Viewer3DPreset {
  id        String   @id @default(uuid())
  name      String
  config    String   // JSON con tutti i valori della configurazione
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
