generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Kit {
  id           String      @id
  name         String
  team         String
  type         String
  imageUrl     String?
  model3DUrl   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime
  logoUrl      String?
  detail1Label String?
  detail1Url   String?
  detail2Label String?
  detail2Url   String?
  detail3Label String?
  detail3Url   String?
  detail4Label String?
  detail4Url   String?
  detail5Label String?
  detail5Url   String?
  detail6Label String?
  detail6Url   String?
  PlayerKit    PlayerKit[]
}

model Nation {
  id        String   @id
  name      String   @unique
  code      String   @unique
  flag      String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  Player    Player[]
}

model Player {
  id        String      @id
  name      String
  surname   String?
  nationId  String?
  image     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime
  biography String?
  Nation    Nation?     @relation(fields: [nationId], references: [id])
  PlayerKit PlayerKit[]
}

model PlayerKit {
  id        String   @id
  playerId  String
  kitId     String
  createdAt DateTime @default(now())
  updatedAt DateTime
  Player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  Kit       Kit      @relation(fields: [kitId], references: [id], onDelete: Cascade)

  @@unique([playerId, kitId])
}
